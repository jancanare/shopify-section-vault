{%- style -%}
  .trust-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 40px 20px;
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 30px;
  }
  .trust-item-{{ section.id }} {
    flex: 1;
    min-width: 200px;
    text-align: center;
    max-width: 300px;
  }
  .trust-icon-{{ section.id }} img, .trust-icon-{{ section.id }} svg {
    width: 45px;
    height: 45px;
    margin-bottom: 15px;
    fill: {{ section.settings.icon_color }};
  }
  .trust-title-{{ section.id }} {
    font-weight: bold;
    margin-bottom: 5px;
    color: {{ section.settings.text_color }};
  }
  .trust-text-{{ section.id }} {
    font-size: 0.9rem;
    color: {{ section.settings.text_color }};
    opacity: 0.8;
  }
{%- endstyle -%}

<div class="trust-bar-{{ section.id }}">
  {% for block in section.blocks %}
    <div class="trust-item-{{ section.id }}" {{ block.shopify_attributes }}>
      <div class="trust-icon-{{ section.id }}">
        {% if block.settings.icon_svg != blank %}
          {{ block.settings.icon_svg }}
        {% elsif block.settings.icon_image != blank %}
          {{ block.settings.icon_image | image_url: width: 100 | image_tag }}
        {% endif %}
      </div>
      <div class="trust-title-{{ section.id }}">{{ block.settings.title }}</div>
      <div class="trust-text-{{ section.id }}">{{ block.settings.subtext }}</div>
    </div>
  {% endfor %}
</div>

{% schema %}
{
  "name": "Pro Trust Bar",
  "max_blocks": 4,
  "settings": [
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f9f9f9" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#333333" },
    { "type": "color", "id": "icon_color", "label": "Icon Color (SVG only)", "default": "#000000" }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        { "type": "html", "id": "icon_svg", "label": "SVG Code (Optional)" },
        { "type": "image_picker", "id": "icon_image", "label": "Icon Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtext", "label": "Subtext", "default": "On all orders today" }
      ]
    }
  ]
}
{% endschema %}